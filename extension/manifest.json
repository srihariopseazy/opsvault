{
  "manifest_version": 3,
  "name": "OPSVAULT",
  "version": "1.0.0",
  "description": "Auto-fill passwords from your OPSVAULT vault",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "http://178.105.94.101/*",
    "http://localhost:8000/*",
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "OPSVAULT",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["autofill.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
